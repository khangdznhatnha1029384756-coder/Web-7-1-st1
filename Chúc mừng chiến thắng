<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chiến Thắng 7-1 - Developer Khang</title>
    <style>
        :root {
            --gold: #ffd700;
            --dark: #121212;
            --white: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--dark);
            color: var(--white);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100-vh;
            overflow-x: hidden;
        }

        .celebration-container {
            text-align: center;
            width: 90%;
            max-width: 800px;
            padding: 20px;
            border: 2px solid var(--gold);
            border-radius: 15px;
            background: rgba(255, 215, 0, 0.05);
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.2);
        }

        .header h1 {
            font-size: 3rem;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
        }

        .score-board {
            font-size: 5rem;
            font-weight: bold;
            margin: 20px 0;
            display: flex;
            justify-content: center;
            gap: 30px;
        }

        .media-slot {
            width: 100%;
            margin: 20px 0;
            border-radius: 10px;
            overflow: hidden;
            background: #222;
        }

        /* Hình ảnh edit */
        .victory-img {
            width: 100%;
            height: auto;
            display: block;
            border: 1px solid #333;
        }

        /* Video edit */
        .victory-video {
            width: 100%;
            aspect-ratio: 16 / 9;
        }

        .footer-info {
            margin-top: 30px;
            font-style: italic;
            color: #aaa;
        }

        .dev-name {
            color: var(--gold);
            font-weight: bold;
            text-decoration: none;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        .highlight {
            display: inline-block;
            animation: pulse 2s infinite;
        }
    </style>
</head>
<body>

<div class="celebration-container">
    <div class="header">
        <h1>CHÚC MỪNG CHIẾN THẮNG</h1>
        <p class="highlight">Giải bóng đá vô địch</p>
    </div>

    <div class="score-board">
        <span>7</span>
        <span>-</span>
        <span>1</span>
    </div>

    <div class="media-slot">
        <img src="DUONG_DAN_ANH_CUA_BAN.jpg" alt="Hình ảnh ăn mừng" class="victory-img">
    </div>

    <div class="media-slot">
        <video controls class="victory-video">
            <source src="DUONG_DAN_VIDEO_CUA_BAN.mp4" type="video/mp4">
            Trình duyệt của bạn không hỗ trợ video.
        </video>
    </div>

    <div class="footer-info">
        <p>Phát triển bởi <span class="dev-name">Developer Khang</span></p>
    </div>
</div>

</body>
</html>

